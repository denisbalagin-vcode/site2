---
interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

import { ClientRouter } from 'astro:transitions';
import { asset } from '../utils/asset';
import { email, phones, telegram, address } from '../data/contacts';

const {
  title = 'Web-сервис для расчета инсоляции и КЕО | Formit',
  description = 'Formit — web-сервис для расчёта инсоляции и КЕО. Загрузите Revit-модель и получите полный расчёт с готовым отчётом для экспертизы.',
  keywords = 'Formit, Инсоляция, КЕО, Концепция, ПД, расчёт инсоляции, КЕО расчёт, Revit',
  ogImage = '/images/insolatedBuilding.BsJLrvJH.webp',
} = Astro.props;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : '';
const toAbsoluteUrl = (url: string) => {
  if (/^https?:\/\//.test(url)) return url;
  const withBase = asset(url);
  return Astro.site ? new URL(withBase, Astro.site).href : withBase;
};
const ogImageUrl = toAbsoluteUrl(ogImage);

// Аналитика подключается только когда задан домен (см. utils/analytics.ts).
// Пока переменная не задана — скрипт не рендерится, трекинг — no-op.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN as string | undefined;
const plausibleSrc =
  (import.meta.env.PUBLIC_PLAUSIBLE_SRC as string | undefined) ?? 'https://plausible.io/js/script.js';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />

    <!-- Тема: выставляем data-theme до отрисовки тела, чтобы не было мигания (FOUC).
         Сохранённый выбор имеет приоритет над системной темой.
         astro:before-swap переносит тему на новый документ до свапа при SPA-навигации. -->
    <script is:inline>
      (function () {
        function applyTheme(doc) {
          try {
            var saved = localStorage.getItem('theme');
            var system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            doc.documentElement.dataset.theme = saved === 'light' || saved === 'dark' ? saved : system;
          } catch (e) {
            doc.documentElement.dataset.theme = 'light';
          }
        }
        applyTheme(document);
        document.addEventListener('astro:before-swap', function (e) {
          applyTheme(e.newDocument);
        });
      })();
    </script>

    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Formit" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content="Formit" />
    <meta property="og:locale" content="ru_RU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={asset('/favicon.svg')} />

    <!-- Preload critical fonts -->
    <link rel="preload" as="font" href={asset('/fonts/montserrat-600.woff2')} type="font/woff2" crossorigin />
    <link rel="preload" as="font" href={asset('/fonts/montserrat-700.woff2')} type="font/woff2" crossorigin />

    <!-- Heading font: Space Grotesk -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&display=swap" />

    <title>{title}</title>

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "Formit",
      "url": "https://formit.pro",
      "logo": "https://formit.pro/favicon.svg",
      "description": description,
      "telephone": phones.map((p) => p.label),
      "email": email,
      "address": {
        "@type": "PostalAddress",
        "addressCountry": address.country,
        "addressLocality": address.locality,
        "postalCode": address.postalCode,
        "streetAddress": address.street
      },
      "sameAs": [telegram.url]
    })} />

    {plausibleDomain && (
      <script is:inline defer data-domain={plausibleDomain} src={plausibleSrc}></script>
    )}

    <!-- Плавная навигация без полной перезагрузки (View Transitions). -->
    <ClientRouter />

    <!-- Доп. теги в <head> для отдельных страниц (например, JSON-LD статьи). -->
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // Module-scoped: при SPA-навигации (ClientRouter) отключаем предыдущий
  // observer, чтобы он не оставался висеть на свапнутых узлах.
  let fadeObserver: IntersectionObserver | null = null;

  function initFadeIn() {
    fadeObserver?.disconnect();
    const els = document.querySelectorAll<HTMLElement>('.fade-in');
    if (!els.length) {
      fadeObserver = null;
      return;
    }
    fadeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            fadeObserver?.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );
    els.forEach((el) => fadeObserver!.observe(el));
  }

  initFadeIn();
  document.addEventListener('astro:page-load', initFadeIn);
</script>
