---
interface Props {
  /** Текущий продукт (для подсветки активного в product nav). */
  currentProduct?: 'pd' | 'conception' | 'tep' | 'formit-ai';
  /** Скрыть ссылку на демо на самой странице демо. */
  showDemoLink?: boolean;
  /** Скрыть ссылку на статьи в разделе статей. */
  showArticlesLink?: boolean;
  /** Показать раздел с якорными ссылками в мобильном меню (только для ПД). */
  showSectionNav?: boolean;
}

const {
  currentProduct,
  showDemoLink = true,
  showArticlesLink = true,
  showSectionNav = false,
} = Astro.props;

import Logo from './ui/Logo.astro';
import FormSubmission from './FormSubmission.tsx';
import { asset } from '../utils/asset';
import { docs, accountUrl } from '../data/contacts';

// Навигация по продуктам
const productLinks = [
  { label: 'ПД', href: asset('/'), id: 'pd' },
  { label: 'Концепция', href: asset('/conception'), id: 'conception' },
  { label: 'FormitAI', href: asset('/formit-ai'), id: 'formit-ai' },
];

// Якорные ссылки на разделы (только в мобильном меню ПД-страницы)
const sectionLinksFull = [
  { label: 'Кому подойдёт', target: 'audience' },
  { label: 'Этапы', target: 'stages' },
  { label: 'Видео', target: 'video' },
  { label: 'Экспертизы', target: 'expertises' },
  { label: 'Отзывы', target: 'reviews' },
  { label: 'Стоимость', target: 'pricing' },
  { label: 'Вопросы', target: 'faq' },
  { label: 'Контакты', target: 'contacts' },
];

// Внешние ссылки на документацию (выпадающее меню)
const docLinks = [
  { label: 'Руководство пользователя', href: docs.manual },
  { label: 'Методические указания', href: docs.guidelines },
  { label: 'Что нового', href: docs.changelog },
];
---

<header class="header" data-site-header data-scrolled="false">
  <div class="header__inner">
    <!-- Логотип -->
    <a href={asset('/')} class="header__logo" aria-label="Formit — на главную">
      <Logo />
    </a>

    <!-- Product навигация (десктоп) -->
    <nav class="nav-pill" aria-label="Продукты">
      {
        productLinks.map((link) => (
          <a
            class="nav-pill__link"
            href={link.href}
            aria-current={currentProduct === link.id ? 'true' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Правый блок (десктоп). Порядок слева направо:
         Статьи · Демо · Документация · Войти · Смена темы -->
    <div class="header__actions">
      {
        showArticlesLink && (
          <a class="header__link" href={asset('/articles')}>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
            <span>Статьи</span>
          </a>
        )
      }

      {
        showDemoLink && (
          <a class="header__link header__demo" href={asset('/demo')}>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M8 5.14v13.72a1 1 0 0 0 1.54.84l10.78-6.86a1 1 0 0 0 0-1.68L9.54 4.3A1 1 0 0 0 8 5.14Z"
                fill="currentColor"
                stroke="none"
              />
            </svg>
            <span>Демо</span>
          </a>
        )
      }

      <!-- Выпадающее меню документации -->
      <div class="dropdown" data-dropdown data-open="false">
        <button
          type="button"
          class="dropdown__toggle"
          data-dropdown-toggle
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <span>Документация</span>
          <svg
            width="10"
            height="6"
            viewBox="0 0 10 6"
            fill="none"
            class="dropdown__caret"
            aria-hidden="true"
          >
            <path
              d="M1 1L5 5L9 1"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </button>
        <div class="dropdown__menu" data-dropdown-menu role="menu">
          {
            docLinks.map((link) => (
              <a
                class="dropdown__item"
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                role="menuitem"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Вход в веб-сервис (личный кабинет) -->
      <a
        class="header__login"
        href={accountUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span>Войти</span>
      </a>

      <!-- CTA: заявка (десктоп) -->
      <FormSubmission
        client:load
        buttonText="Оставить заявку"
        variant="filled"
        size="small"
        buttonClass="header__cta"
      />

      <!-- Переключатель темы -->
      <button
        type="button"
        class="theme-toggle"
        data-theme-toggle
        aria-label="Переключить тему"
        title="Светлая / тёмная тема"
      >
        <svg
          class="theme-toggle__icon theme-toggle__icon--sun"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
        <svg
          class="theme-toggle__icon theme-toggle__icon--moon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>

    <!-- Бургер (мобильные) -->
    <button
      type="button"
      class="burger"
      data-menu-toggle
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Открыть меню"
    >
      <svg
        class="burger__icon burger__icon--open"
        width="20"
        height="20"
        viewBox="0 0 18 18"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M2 4.5H16"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
        <path
          d="M2 9H16"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
        <path
          d="M2 13.5H16"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
      </svg>
      <svg
        class="burger__icon burger__icon--close"
        width="20"
        height="20"
        viewBox="0 0 18 18"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M4 4L14 14"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
        <path
          d="M14 4L4 14"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>
</header>

<!-- Мобильное меню-шторка -->
<div id="mobile-menu" class="mobile-menu" data-mobile-menu>
  <div class="mobile-menu__inner">
    <button type="button" class="mobile-menu__theme" data-theme-toggle>
      <span class="mobile-menu__theme-label" data-theme-label>Тёмная тема</span>
      <svg
        class="theme-toggle__icon theme-toggle__icon--sun"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
        ></path>
      </svg>
      <svg
        class="theme-toggle__icon theme-toggle__icon--moon"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- Product-навигация в мобильном меню -->
    <p class="mobile-menu__label">Продукты</p>
    <div class="mobile-menu__group">
      {
        productLinks.map((link) => (
          <a
            class="mobile-menu__link"
            href={link.href}
            aria-current={currentProduct === link.id ? 'true' : undefined}
            data-mobile-close
          >
            {link.label}
          </a>
        ))
      }
    </div>

    {
      showSectionNav && (
        <>
          <div class="mobile-menu__divider" />
          <p class="mobile-menu__label">Разделы</p>
          <div class="mobile-menu__group">
            {sectionLinksFull.map((link) => (
              <a
                class="mobile-menu__link mobile-menu__link--muted"
                href={`#${link.target}`}
                data-section-link
                data-section-target={link.target}
                data-mobile-close
              >
                {link.label}
              </a>
            ))}
          </div>
        </>
      )
    }

    <div class="mobile-menu__divider"></div>

    {
      showArticlesLink && (
        <a
          class="mobile-menu__link mobile-menu__link--demo"
          href={asset('/articles')}
          data-mobile-close
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          Статьи
        </a>
      )
    }

    {
      showDemoLink && (
        <a
          class="mobile-menu__link mobile-menu__link--demo"
          href={asset('/demo')}
          data-mobile-close
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M8 5.14v13.72a1 1 0 0 0 1.54.84l10.78-6.86a1 1 0 0 0 0-1.68L9.54 4.3A1 1 0 0 0 8 5.14Z" />
          </svg>
          Демо продукта
        </a>
      )
    }

    <a
      class="mobile-menu__link mobile-menu__link--demo"
      href={accountUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-mobile-close
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      Войти в аккаунт
    </a>

    <div class="mobile-menu__divider"></div>

    <p class="mobile-menu__label">Документация</p>
    <div class="mobile-menu__group">
      {
        docLinks.map((link) => (
          <a
            class="mobile-menu__link mobile-menu__link--muted"
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            data-mobile-close
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <FormSubmission
      client:load
      buttonText="Попробовать сервис"
      variant="filled"
      size="normal"
      buttonClass="mobile-menu__cta"
    />
  </div>
</div>

<style>
  /* ============================================================
     ХЕДЕР — фиксированный, с размытием фона
     ============================================================ */
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: var(--z-header);
    height: var(--header-height);
    display: flex;
    align-items: center;
    background: var(--header-bg);
    -webkit-backdrop-filter: blur(var(--header-blur));
    backdrop-filter: blur(var(--header-blur));
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .header[data-scrolled='true'] {
    border-bottom-color: var(--color-border-navbar);
    box-shadow:
      0 1px 0 var(--color-border-navbar),
      var(--shadow-sm);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    width: 100%;
    max-width: var(--container-max-width);
    margin-inline: auto;
    padding-inline: var(--container-padding-x);
  }

  .header__logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* ============================================================
     PILL-НАВИГАЦИЯ
     ============================================================ */
  .nav-pill {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: 4px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: transparent;
  }

  .nav-pill__link {
    white-space: nowrap;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .nav-pill__link:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  .nav-pill__link[aria-current='true'] {
    background: var(--color-accent-soft);
    color: var(--color-accent-primary);
    font-weight: var(--font-weight-semibold);
  }

  .nav-pill__link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /* ============================================================
     ПРАВЫЙ БЛОК + ВЫПАДАЮЩЕЕ МЕНЮ
     ============================================================ */
  .header__actions {
    flex-shrink: 0;
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    justify-self: end;
  }

  /* CTA-кнопка заявки в шапке — компактнее, с лёгким свечением */
  .header__actions :global(.header__cta) {
    box-shadow: 0 2px 10px
      color-mix(in srgb, var(--color-accent-primary) 25%, transparent);
  }

  /* Все текстовые элементы правого блока — единый ghost-стиль.
     Применяется к: .header__link (Статьи, Демо), .header__login (Войти),
     .dropdown__toggle (Документация). */
  .header__link,
  .header__login,
  .dropdown__toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-full);
    border: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .header__link:hover,
  .header__login:hover,
  .dropdown__toggle:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
  }

  /* Иконки внутри ссылок — акцентный цвет */
  .header__link svg,
  .header__login svg {
    color: var(--color-accent-primary);
    flex-shrink: 0;
  }

  /* Переключатель темы */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .theme-toggle:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    background: var(--color-accent-soft);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /* Иконки: показываем «луну» в светлой теме (клик → тёмная),
     «солнце» — в тёмной (клик → светлая). */
  .theme-toggle > .theme-toggle__icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .theme-toggle > .theme-toggle__icon--sun {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(-90deg) scale(0.7);
  }

  .theme-toggle > .theme-toggle__icon--moon {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
  }

  :global(:root[data-theme='dark']) .theme-toggle > .theme-toggle__icon--sun {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
  }

  :global(:root[data-theme='dark']) .theme-toggle > .theme-toggle__icon--moon {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scale(0.7);
  }

  .mobile-menu__theme .theme-toggle__icon--sun {
    display: none;
  }
  .mobile-menu__theme .theme-toggle__icon--moon {
    display: block;
  }

  :global(:root[data-theme='dark'])
    .mobile-menu__theme
    .theme-toggle__icon--sun {
    display: block;
  }
  :global(:root[data-theme='dark'])
    .mobile-menu__theme
    .theme-toggle__icon--moon {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle > .theme-toggle__icon {
      transition: none;
    }
  }

  .dropdown {
    position: relative;
  }

  .dropdown__caret {
    transition: transform var(--transition-fast);
  }

  .dropdown[data-open='true'] .dropdown__caret {
    transform: rotate(180deg);
  }

  .dropdown__menu {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 240px;
    padding: 6px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg-primary);
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast),
      visibility var(--transition-fast);
  }

  .dropdown[data-open='true'] .dropdown__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown__item {
    display: block;
    padding: 0.625rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .dropdown__item:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  /* ============================================================
     БУРГЕР
     ============================================================ */
  .burger {
    display: none;
    margin-left: auto;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    transition: background-color var(--transition-fast);
  }

  .burger:hover {
    background: var(--color-bg-secondary);
  }

  .burger__icon--close {
    display: none;
  }

  .burger[aria-expanded='true'] .burger__icon--open {
    display: none;
  }

  .burger[aria-expanded='true'] .burger__icon--close {
    display: block;
  }

  /* ============================================================
     МОБИЛЬНОЕ МЕНЮ-ШТОРКА
     ============================================================ */
  .mobile-menu {
    position: fixed;
    inset-inline: 0;
    top: var(--header-height);
    bottom: 0;
    z-index: calc(var(--z-header) - 1);
    overflow-y: auto;
    background: var(--color-bg-primary);
    border-top: 1px solid var(--color-border-navbar);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast),
      visibility var(--transition-fast);
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mobile-menu__inner {
    padding: var(--space-6) var(--container-padding-x) var(--space-10);
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .mobile-menu__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .mobile-menu__link {
    padding: 0.75rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .mobile-menu__link:hover,
  .mobile-menu__link[aria-current='true'] {
    background: var(--color-accent-soft);
    color: var(--color-accent-primary);
  }

  .mobile-menu__link--muted {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
  }

  .mobile-menu__link--demo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-accent-primary);
  }

  .mobile-menu__link--demo svg {
    flex-shrink: 0;
  }

  .mobile-menu__divider {
    height: 1px;
    background: var(--color-border);
    margin-block: var(--space-5);
  }

  .mobile-menu__cta {
    margin-top: var(--space-6);
    width: 100%;
    justify-content: center;
  }

  .mobile-menu__theme {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    padding: 0.75rem;
    margin-bottom: var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    transition: background-color var(--transition-fast);
  }

  .mobile-menu__theme:hover {
    background: var(--color-bg-secondary);
  }

  .mobile-menu__theme-label {
    margin-right: auto;
  }

  /* ============================================================
     АДАПТИВНОСТЬ
     ============================================================ */

  /* Ниже 1260px pill-навигация и правые действия прячутся, появляется бургер.
     1280px — самый распространённый размер ноутбука, он проходит без бургера.
     1200px и ниже — уже нет места, показываем бургер. */
  @media (max-width: 1260px) {
    .nav-pill,
    .header__actions {
      display: none;
    }

    .burger {
      display: inline-flex;
    }
  }
</style>

<script>
  import { track } from '../utils/analytics';

  // Module-scoped: при SPA-навигации (ClientRouter) body свапается, но слушатели
  // на window/document переживают swap. Снимаем их перед повторной инициализацией,
  // иначе они накапливаются от страницы к странице.
  let cleanup: (() => void) | null = null;

  function initHeader() {
    cleanup?.();
    cleanup = null;

    const header = document.querySelector(
      '[data-site-header]',
    ) as HTMLElement | null;
    if (!header) return;

    // Все слушатели вешаются с этим сигналом: cleanup снимает их одним
    // abort(). Без этого initHeader, вызванный повторно (initial +
    // astro:page-load), навешивал вторые слушатели на те же кнопки — и
    // toggle-обработчики (тема, дропдаун) срабатывали дважды за клик.
    const ac = new AbortController();
    const { signal } = ac;

    // 1. Тень/граница хедера при прокрутке
    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 8 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true, signal });

    // 2. Подсветка активного раздела
    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-section-link]'),
    );
    const linksByTarget = new Map<string, HTMLAnchorElement[]>();
    links.forEach((link) => {
      const target = link.dataset.sectionTarget;
      if (!target) return;
      const list = linksByTarget.get(target) ?? [];
      list.push(link);
      linksByTarget.set(target, list);
    });

    const sections = Array.from(linksByTarget.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    let sectionObserver: IntersectionObserver | null = null;
    if (sections.length) {
      sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            links.forEach((l) => l.removeAttribute('aria-current'));
            const active = linksByTarget.get(entry.target.id);
            active?.forEach((l) => l.setAttribute('aria-current', 'true'));
          });
        },
        { rootMargin: '-45% 0px -50% 0px', threshold: 0 },
      );
      sections.forEach((s) => sectionObserver!.observe(s));
    }

    // Закрывалки попапов — собираем, чтобы общий onDocKeydown (Escape) и
    // onDocClick могли их вызвать, а cleanup — снять глобальные слушатели.
    let closeDropdown: (() => void) | null = null;
    let closeMenu: (() => void) | null = null;

    // 3. Выпадающее меню документации
    const dropdown = document.querySelector<HTMLElement>('[data-dropdown]');
    const dropdownToggle = dropdown?.querySelector<HTMLButtonElement>(
      '[data-dropdown-toggle]',
    );
    if (dropdown && dropdownToggle) {
      const setDropdown = (open: boolean) => {
        dropdown.dataset.open = open ? 'true' : 'false';
        dropdownToggle.setAttribute('aria-expanded', String(open));
      };
      closeDropdown = () => setDropdown(false);
      dropdownToggle.addEventListener(
        'click',
        (e) => {
          e.stopPropagation();
          setDropdown(dropdown.dataset.open !== 'true');
        },
        { signal },
      );
    }

    // 4. Мобильное меню
    const toggle =
      document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    if (toggle && menu) {
      const setMenu = (open: boolean) => {
        menu.classList.toggle('is-open', open);
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute(
          'aria-label',
          open ? 'Закрыть меню' : 'Открыть меню',
        );
        document.body.style.overflow = open ? 'hidden' : '';
      };
      closeMenu = () => setMenu(false);
      toggle.addEventListener(
        'click',
        () => {
          setMenu(!menu.classList.contains('is-open'));
        },
        { signal },
      );
      menu.querySelectorAll('[data-mobile-close]').forEach((link) => {
        link.addEventListener('click', () => setMenu(false), { signal });
      });
    }

    // Глобальные слушатели для закрытия попапов (один раз, снимаются в cleanup).
    const onDocClick = () => closeDropdown?.();
    const onDocKeydown = (e: KeyboardEvent) => {
      if (e.key !== 'Escape') return;
      closeDropdown?.();
      closeMenu?.();
    };
    document.addEventListener('click', onDocClick, { signal });
    document.addEventListener('keydown', onDocKeydown, { signal });

    // 5. Переключатель темы (light/dark) с сохранением выбора
    const themeToggles = document.querySelectorAll<HTMLButtonElement>(
      '[data-theme-toggle]',
    );
    const themeLabels =
      document.querySelectorAll<HTMLElement>('[data-theme-label]');
    const syncThemeLabel = () => {
      const isDark = document.documentElement.dataset.theme === 'dark';
      themeLabels.forEach((l) => {
        l.textContent = isDark ? 'Светлая тема' : 'Тёмная тема';
      });
    };
    syncThemeLabel();
    themeToggles.forEach((btn) => {
      btn.addEventListener(
        'click',
        () => {
          const next =
            document.documentElement.dataset.theme === 'dark'
              ? 'light'
              : 'dark';
          const root = document.documentElement;
          const reduceMotion = window.matchMedia(
            '(prefers-reduced-motion: reduce)',
          ).matches;
          const applyTheme = () => {
            root.dataset.theme = next;
            try {
              localStorage.setItem('theme', next);
            } catch (e) {
              /* localStorage может быть недоступен */
            }
            syncThemeLabel();
          };

          if (reduceMotion) {
            applyTheme();
            return;
          }

          // Тема применяется синхронно: плавность даёт класс
          // theme-transitioning (анимация цветов в global.css).
          root.classList.add('theme-transitioning');
          applyTheme();
          window.setTimeout(
            () => root.classList.remove('theme-transitioning'),
            280,
          );
        },
        { signal },
      );
    });

    // 6. Аналитика: переход в демо (no-op, пока аналитика не подключена)
    document
      .querySelectorAll<HTMLAnchorElement>(
        '.header__demo, .mobile-menu__link--demo',
      )
      .forEach((link) =>
        link.addEventListener('click', () => track('demo_click'), { signal }),
      );

    // Снятие глобальных слушателей и observer перед следующей навигацией.
    cleanup = () => {
      ac.abort();
      sectionObserver?.disconnect();
    };
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
