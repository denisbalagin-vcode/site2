---
import Button from '../ui/Button.astro';
import { asset } from '../../utils/asset';

const gipFeatures = [
  {
    icon: asset('/images/exportIcon.v-0Nq4nd.gif'),
    iconAlt: 'Экспорт',
    title: 'Экспорт модели напрямую из Revit',
    subtitle: 'После внесения изменений, модель обновляется в 1 клик',
  },
  {
    icon: asset('/images/reportIcon.BHVjrbWR.gif'),
    iconAlt: 'Отчет',
    title: 'Формирование документации для экспертизы',
    subtitle: 'Гибкий конструктор отчетов с автоматическим формированием графики и текста',
  },
  {
    icon: asset('/images/roomPlanIcon.DayKlSI4.gif'),
    iconAlt: 'План комнаты',
    title: 'Нет перепланировкам',
    subtitle: 'Возможность быстрой проверки инсоляции и КЕО на любом этапе проектирования',
  },
];

const bimFeatures = [
  {
    icon: '⏱',
    isEmoji: true,
    title: 'Скорость расчета',
    subtitle: '1000 светопроемов / мин',
  },
  {
    icon: 'до\n23%',
    isText: true,
    title: 'Автоматизировать расчеты инсоляции и КЕО',
    subtitle: '— снижение времени проектирования',
  },
  {
    icon: '~\n40\nмин',
    isText: true,
    title: 'Совместимо с Autodesk и BIM-системами',
    subtitle: '— чтобы разобраться в сервисе + оперативная служба поддержки',
  },
];

const ceoStats = [
  { value: '10 мин',   label: 'на расчет 1 проекта' },
  { value: 'до 30%',   label: 'снижения потерь' },
  { value: '>120',     label: 'компаний используют Formit' },
];

const ceoFeatures = [
  {
    title: 'Брать больше заказов',
    subtitle: 'На расчет 1 проекта у архитектора уйдет 10 минут',
  },
  {
    title: 'Снизить потери прибыли из-за переделок до 30%',
    subtitle: 'Сервис поддерживает "Быстрый расчет" после изменений в проекте на любом этапе',
  },
  {
    title: 'Работа в сертифицированном сервисе',
    subtitle: 'Более 120 компаний уже используют Formit',
  },
];
---

<section id="audience" class="section section--bg-primary audience fade-in">
  <div class="container">
    <h2 class="section-title h2">Сервис подойдет</h2>

    <div class="audience__cards">
      <!-- Карточка: ГИП и ГАП -->
      <div class="card card--soft card--interactive">
        <h3 class="card__title">ГИП и ГАП</h3>
        <ul class="feature-list">
          {gipFeatures.map(f => (
            <li class="feature-item">
              <div class="feature-item__icon feature-item__icon--default">
                <img src={f.icon} width="60" height="60" alt={f.iconAlt} loading="lazy" decoding="async" />
              </div>
              <div>
                <p class="feature-item__title">{f.title}</p>
                <p class="feature-item__subtitle">{f.subtitle}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Карточка: BIM-менеджерам -->
      <div class="card card--filled card--interactive">
        <h3 class="card__title">BIM-менеджерам</h3>
        <ul class="feature-list">
          {bimFeatures.map(f => (
            <li class="feature-item">
              <div class:list={['feature-item__icon', 'feature-item__icon--bg', f.isText && 'feature-item__icon--text']}>
                {f.isText
                  ? <span set:html={f.icon.replace(/\n/g, '<br/>')} />
                  : f.icon
                }
              </div>
              <div>
                <p class="feature-item__title">{f.title}</p>
                <p class="feature-item__subtitle">{f.subtitle}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Карточка: Генеральным директорам -->
      <div class="card card--soft card--interactive ceo-card">
        <div class="ceo-card__top">
          <h3 class="card__title">Генеральным директорам</h3>
          <div class="ceo-stats">
            {ceoStats.map(s => (
              <div class="ceo-stat">
                <span class="ceo-stat__value">{s.value}</span>
                <span class="ceo-stat__label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
        <ul class="feature-list feature-list--no-icon">
          {ceoFeatures.map(f => (
            <li class="feature-item">
              <div>
                <p class="feature-item__title">{f.title}</p>
                <p class="feature-item__subtitle">{f.subtitle}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .audience__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-6);
  }

  /* Карточка CEO занимает всю нижнюю строку */
  .ceo-card {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .ceo-card__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .ceo-card__top .card__title {
    margin-bottom: 0;
  }

  /* --- Feature list --- */
  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .feature-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .feature-item__icon {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
  }

  .feature-item__icon--default {
    background: transparent;
  }

  .feature-item__icon--bg {
    background: rgba(255,255,255,0.15);
    font-size: var(--font-size-xl);
  }

  .feature-item__icon--text {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    white-space: pre-line;
    text-align: center;
    line-height: 1.2;
  }

  .feature-item__title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-1);
  }

  .feature-item__subtitle {
    font-size: var(--font-size-sm);
    opacity: 0.7;
    line-height: var(--line-height-normal);
  }

  /* --- CEO stats --- */
  .ceo-stats {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .ceo-stat__value {
    display: block;
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent-primary);
    line-height: 1;
  }

  .ceo-stat__label {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }

  @media (max-width: 900px) {
    .audience__cards {
      grid-template-columns: 1fr;
    }

    .ceo-card {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 601px) and (max-width: 900px) {
    .ceo-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
  }
</style>
