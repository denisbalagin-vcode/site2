---
import { asset } from '../../utils/asset';
const departments = [
  {
    title: null,
    isCeo: true,
    members: [
      {
        photo: asset('/images/anastasiyaSiluyanova.CuaiZH0j.webp'),
        name: 'Анастасия Силуянова',
        role: 'Генеральный директор',
        bio: [
          'Работает с зарождения сервиса. Прошла путь от специалиста технической поддержки до генерального директора.',
          'Формирует видение продукта и прокачивает репутацию продукта на рынке.',
          'Реализовала верификацию сервиса в НИИСФ РААСН.',
        ],
      },
    ],
  },
  {
    title: 'Менеджеры по продукту',
    members: [
      {
        photo: asset('/images/tatyanaKorotinskaya.BTxxRB9P.webp'),
        name: 'Татьяна Коротинская',
      },
    ],
  },
  {
    title: 'Техническая поддержка',
    members: [
      {
        photo: asset('/images/tatyanaKrestnikova.Bd70MgbJ.webp'),
        name: 'Татьяна Крестникова',
      },
      {
        photo: asset('/images/alexandraIgnatova.Dk3HuI_b.webp'),
        name: 'Александра Игнатова',
      },
    ],
  },
  {
    title: 'Программисты',
    members: [
      {
        photo: asset('/images/matveyKupriyanov.CjERHxKf.webp'),
        name: 'Матвей Куприянов',
      },
      { photo: asset('/images/vladislav.lRKiQW9v.webp'), name: 'Владислав' },
      {
        photo: asset('/images/alexanderOleynikov.Bs3pnuFE.webp'),
        name: 'Александр Олейников',
      },
      {
        photo: asset('/images/fedorPichugin.COoPxeeJ.webp'),
        name: 'Федор Пичугин',
      },
      {
        photo: asset('/images/alexanderMescheryakov.DukWLxPa.webp'),
        name: 'Александр Мещеряков',
      },
    ],
  },
];
---

<section id="team" class="section section--bg-secondary team fade-in">
  <div class="container">
    <div class="section-head">
      <span class="section-eyebrow">Кто делает Formit</span>
      <h2 class="section-title h2">Команда</h2>
      <p class="section-subtitle">
        Продукт развивает команда разработчиков, продакт-менеджеров
        и&nbsp;технической поддержки.
      </p>
    </div>

    {
      departments.map((dept) => (
        <div class:list={['team__dept', dept.isCeo && 'team__dept--ceo']}>
          {dept.title && <h4 class="team__dept-title">{dept.title}</h4>}

          {dept.isCeo ? (
            <div class="ceo-block">
              {dept.members.map((m) => (
                <>
                  <div class="member-card member-card--large">
                    <img
                      src={m.photo}
                      alt={m.name}
                      loading="lazy"
                      decoding="async"
                      class="member-card__photo"
                    />
                  </div>
                  <div class="ceo-block__info">
                    <p class="ceo-block__role">{m.role}</p>
                    <h3 class="ceo-block__name">{m.name}</h3>
                    <ul class="ceo-block__bio">
                      {m.bio?.map((b) => (
                        <li>{b}</li>
                      ))}
                    </ul>
                  </div>
                </>
              ))}
            </div>
          ) : (
            <div class="team__members">
              {dept.members.map((m) => (
                <div class="member-card">
                  <img
                    src={m.photo}
                    alt={m.name}
                    loading="lazy"
                    decoding="async"
                    class="member-card__photo"
                  />
                  {m.name && <p class="member-card__name">{m.name}</p>}
                </div>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>

<style>
  .team__dept {
    margin-bottom: var(--space-12);
  }

  .team__dept-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-6);
    color: var(--color-text-secondary);
  }

  .team__members {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  /* --- CEO блок --- */
  .ceo-block {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .ceo-block__role {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  .ceo-block__name {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-5);
  }

  .ceo-block__bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ceo-block__bio li {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-loose);
    padding-left: var(--space-4);
    position: relative;
  }

  .ceo-block__bio li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent-primary);
    font-weight: bold;
  }

  /* --- Карточка участника --- */
  .member-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    text-align: center;
  }

  .member-card__photo {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-xl);
    object-fit: cover;
    background: var(--color-bg-secondary);
    transition: transform var(--transition-normal);
  }

  .member-card:hover .member-card__photo {
    transform: scale(1.05);
  }

  .member-card--large .member-card__photo {
    width: 100%;
    height: 320px;
    border-radius: var(--card-border-radius);
  }

  .member-card--large:hover .member-card__photo {
    transform: none;
  }

  .member-card__name {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
  }

  @media (max-width: 900px) {
    .team__members {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      justify-items: center;
    }
  }

  @media (max-width: 768px) {
    .ceo-block {
      grid-template-columns: 1fr;
    }

    .member-card--large .member-card__photo {
      height: 240px;
      width: 200px;
      border-radius: var(--card-border-radius);
    }

    .team__members {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
