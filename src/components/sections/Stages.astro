---
const stages = [
  {
    iconSvg: `<svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="60" height="60" rx="12" fill="#e8f0ff"/><path d="M14 18h32M14 24h20M14 30h24M14 36h16M14 42h20" stroke="#0039c5" stroke-width="2.5" stroke-linecap="round"/><rect x="36" y="28" width="12" height="16" rx="2" fill="#0039c5" opacity=".15" stroke="#0039c5" stroke-width="1.5"/></svg>`,
    title: 'Мастер-план',
    isLast: false,
    features: [
      'Индивидуальная точка расчета инсоляции',
      'Адаптивная сетка',
      'Синхронизация Revit модели в 1 клик',
      'Расчет инсоляции территорий',
      'Выгрузка планов с фронтами инсоляции',
      'Расширенная легенда результатов инсоляции',
    ],
  },
  {
    iconSvg: `<svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="60" height="60" rx="12" fill="#e8f0ff"/><path d="M30 14c-7.18 0-13 5.82-13 13 0 4.53 2.32 8.52 5.84 10.84V42a1 1 0 0 0 1 1h12.32a1 1 0 0 0 1-1v-4.16C40.68 35.52 43 31.53 43 27c0-7.18-5.82-13-13-13Z" fill="#0039c5" opacity=".15" stroke="#0039c5" stroke-width="2"/><path d="M26 46h8M28 43v3M32 43v3" stroke="#0039c5" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    title: 'Концепция',
    isLast: false,
    features: [
      'Для проверки инсоляции достаточно построить стены и окна',
      'Возможность проверки влияния на окружающую застройку',
      'Скорость расчета затенения ~ 1000 светопроемов/мин',
      'Можно сформировать отчет',
    ],
  },
  {
    iconSvg: `<svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="60" height="60" rx="12" fill="#e8f0ff"/><rect x="15" y="13" width="30" height="34" rx="3" fill="#0039c5" opacity=".12" stroke="#0039c5" stroke-width="2"/><path d="M21 21h18M21 27h18M21 33h12" stroke="#0039c5" stroke-width="2" stroke-linecap="round"/><circle cx="38" cy="38" r="7" fill="#e8f0ff" stroke="#0039c5" stroke-width="1.8"/><path d="M35 38l2 2 4-4" stroke="#0039c5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Проектная документация',
    isLast: true,
    features: [
      'Минимальные требования к Revit модели',
      'Исключены неточности расчета за счет учета подробной геометрии зданий',
      'Минимизация ручного заполнения',
      'Формирование отчета для прохождения экспертизы',
    ],
  },
];
---

<section id="stages" class="section section--bg-secondary stages fade-in">
  <div class="container">
    <h2 class="section-title h2">Расчеты на всех этапах проектирования</h2>

    <div class="stages__cards">
      {stages.map(stage => (
        <div class="card card--interactive stage-card">
          <div class="stage-card__icon" aria-hidden="true" set:html={stage.iconSvg} />
          <h3 class="stage-card__title">{stage.title}</h3>
          <ul class="stage-card__features">
            {stage.features.map(f => (
              <li>{f}</li>
            ))}
          </ul>

          <!-- Индикатор: стрелка → или галочка ✓ для последнего этапа -->
          <div class="stage-card__action" aria-hidden="true">
            {stage.isLast
              ? (
                <svg width="31" height="22" viewBox="0 0 31 22" fill="currentColor">
                  <path d="m10.6 17.899-.349-.345-7.115-7.004v-.001a1.484 1.484 0 0 0-1.08-.445 1.47 1.47 0 0 0-1.078.445c-.314.307-.465.652-.477 1.055-.012.392.121.724.427 1.023l8.62 8.428c.313.305.657.445 1.054.445s.74-.14 1.053-.445l-1.054-3.156Zm0 0 .351-.343L27.941.946C28.255.64 28.599.5 28.995.5s.741.14 1.054.446c.309.302.451.64.451 1.04 0 .399-.142.736-.45 1.037h-.001L11.656 21.056 10.6 17.899Z" />
                </svg>
              )
              : (
                <svg width="41" height="16" viewBox="0 0 41 16" fill="currentColor">
                  <path d="M40.707 8.707a1 1 0 0 0 0-1.414L34.343.929a1 1 0 1 0-1.414 1.414L38.586 8l-5.657 5.657a1 1 0 0 0 1.414 1.414l6.364-6.364ZM0 9h40V7H0v2Z" />
                </svg>
              )
            }
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stages__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .stage-card {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .stage-card__icon {
    width: 60px;
    height: 60px;
    margin-bottom: var(--space-4);
  }

  .stage-card__title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-5);
    line-height: var(--line-height-tight);
  }

  .stage-card__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .stage-card__features li {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--space-4);
    position: relative;
    line-height: var(--line-height-normal);
  }

  .stage-card__features li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent-primary);
    font-weight: var(--font-weight-bold);
    font-size: 1.2em;
    line-height: 1;
    top: 0.1em;
  }

  .stage-card__action {
    margin-top: var(--space-6);
    align-self: flex-end;
    color: var(--color-accent-secondary);
  }

  @media (max-width: 900px) {
    .stages__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
