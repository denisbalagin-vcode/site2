---
import FormSubmission from '../FormSubmission.tsx';
import { asset } from '../../utils/asset';

const demoHref = asset('/demo');

const plans = [
  {
    id: 'pd',
    name: 'Formit ПД',
    projects: 2,
    priceYear: '300 000 ₽ / год',
    priceMonth: '25 000 ₽ / мес',
    isFeatured: false,
    features: [
      'Расчет инсоляции, КЕО и территорий',
      'Расчет на стадии концепции ПД',
      'Создание отчета для экспертизы',
      'Запуск без привязки к рабочему месту',
    ],
  },
  {
    id: 'pd-plus',
    name: 'Formit ПД+',
    projects: 10,
    priceYear: '350 000 ₽ / год',
    priceMonth: '29 167 ₽ / мес',
    isFeatured: true,
    features: [
      'Расчет инсоляции, КЕО и территорий',
      'Расчет на стадии концепции ПД',
      'Создание отчета для экспертизы',
      'Запуск без привязки к рабочему месту',
      'Одновременный расчет инсоляции, КЕО и территорий',
    ],
  },
  {
    id: 'conception',
    name: 'Formit Conception',
    projects: 10,
    priceYear: '150 000 ₽ / год',
    priceMonth: '12 500 ₽ / мес',
    isFeatured: false,
    features: [
      'Автоматическая разбивка сеткой в сервисе',
      'Расчет инсоляции светопроемов с учетом заглубления окон',
      'Автоматическая сверка с нормативами',
      'Сечение с подсветкой результатов',
      'Расчет инсоляции и массинга, отдельных точек и территорий',
    ],
  },
];
---

<section id="pricing" class="section section--bg-primary pricing fade-in">
  <div class="container">
    <div class="section-head">
      <span class="section-eyebrow">Тарифы</span>
      <h2 class="section-title h2">Стоимость</h2>
      <p class="section-subtitle">
        Выберите тариф под объём ваших проектов — а&nbsp;если сомневаетесь,
        поможем подобрать оптимальный.
      </p>
    </div>

    <div class="pricing__cards">
      {
        plans.map((plan) => (
          <div
            class:list={[
              'card',
              'card--interactive',
              'pricing-card',
              plan.isFeatured ? 'card--featured' : 'card--soft',
              plan.isFeatured && 'pricing-card--featured',
            ]}
          >
            <div class="pricing-card__header">
              <h3 class="pricing-card__name">{plan.name}</h3>
              <p class="pricing-card__projects">
                доступных проектов: <strong>{plan.projects}</strong>
              </p>
            </div>

            <div class="pricing-card__price">
              <span class="pricing-card__price-year">{plan.priceYear}</span>
              <span class="pricing-card__price-month">{plan.priceMonth}</span>
            </div>

            <ul class="pricing-card__features">
              {plan.features.map((f) => (
                <li
                  class:list={[
                    'pricing-card__feature',
                    f.includes('Одновременный') &&
                      'pricing-card__feature--bold',
                  ]}
                >
                  {f}
                </li>
              ))}
            </ul>

            <FormSubmission
              client:load
              buttonText="Оставить заявку"
              variant={plan.isFeatured ? 'filled' : 'outlined'}
              size="normal"
              buttonClass="pricing-card__cta"
            />
          </div>
        ))
      }
    </div>

    <p class="pricing__note">
      Не&nbsp;уверены в&nbsp;выборе? Посмотрите
      <a href={demoHref} class="pricing__note-link">демо продукта</a>
      или оставьте заявку — подберём тариф под вашу задачу.
    </p>
  </div>
</section>

<style>
  .pricing__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    height: 100%;
  }

  /* Обводка + подъём появляются при наведении на карточку */
  .pricing-card:not(.card--featured):hover {
    border-color: var(--color-accent-primary);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  /* Кнопка «Оставить заявку» подсвечивается при наведении на карточку
     (только у обычных тарифов — у рекомендуемого она и так залита) */
  .pricing-card:not(.pricing-card--featured):hover :global(.pricing-card__cta) {
    background: var(--color-accent-primary);
    color: var(--color-text-inverse);
    border-color: var(--color-accent-primary);
    opacity: 1;
  }

  :global(body.formit-modal-open) .pricing-card,
  :global(body.formit-modal-open) .pricing-card:hover {
    transform: none;
  }

  :global(body.formit-modal-open)
    .pricing-card:not(.pricing-card--featured):hover
    :global(.pricing-card__cta) {
    background: transparent;
    color: var(--color-text-primary);
    border-color: var(--color-border);
  }

  .pricing-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pricing-card__name {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .pricing-card--featured .pricing-card__name::after {
    content: 'Рекомендуем';
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    background: var(--gradient-primary);
    color: white;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .pricing-card--featured {
    border-top-width: 3px;
    border-top-color: var(--color-accent-primary);
  }

  .pricing-card__projects {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .pricing-card__projects strong {
    color: var(--color-text-primary);
  }

  .pricing-card__price {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
    border: var(--card-border);
  }

  .pricing-card--featured .pricing-card__price {
    background: color-mix(in srgb, var(--color-accent-primary) 8%, transparent);
    border-color: color-mix(
      in srgb,
      var(--color-accent-primary) 30%,
      transparent
    );
  }

  .pricing-card__price-year {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
  }

  .pricing-card__price-month {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .pricing-card__feature {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-left: var(--space-5);
    position: relative;
    line-height: var(--line-height-normal);
  }

  .pricing-card__feature::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent-primary);
    font-weight: bold;
  }

  .pricing-card__feature--bold {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .pricing-card__cta {
    width: 100%;
    justify-content: center;
  }

  /* Подпись-помощь под тарифами */
  .pricing__note {
    margin-top: var(--space-8);
    text-align: center;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .pricing__note-link {
    color: var(--color-accent-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .pricing__note-link:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 900px) {
    .pricing__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
