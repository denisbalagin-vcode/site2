---
import FormSubmission from '../FormSubmission.tsx';
import { email, phones, telegram, address as companyAddress } from '../../data/contacts';

const contacts = [
  ...phones.map((p) => ({ type: 'phone' as const, label: p.label, href: `tel:${p.tel}` })),
  { type: 'email' as const, label: email, href: `mailto:${email}` },
  { type: 'telegram' as const, label: telegram.handle, href: telegram.url },
];

const address = {
  text: companyAddress.html,
  mapHref: companyAddress.mapUrl,
};
---

<section id="contacts" class="section section--bg-primary contacts fade-in">
  <div class="container contacts__inner">
    <div class="contacts__info">
      <div class="section-head contacts__head">
        <span class="section-eyebrow">Свяжитесь с нами</span>
        <h2 class="section-title h2">Контакты</h2>
      </div>

      <ul class="contacts__list">
        {contacts.map(c => (
          <li>
            <a
              class="contacts__link"
              href={c.href}
              target={c.type === 'telegram' ? '_blank' : undefined}
              rel={c.type === 'telegram' ? 'noopener noreferrer' : undefined}
            >
              <!-- Иконки (телефон / email / telegram) -->
              <span class="contacts__link-icon" aria-hidden="true">
                {c.type === 'phone' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                )}
                {c.type === 'email' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                )}
                {c.type === 'telegram' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M21.94 3.55a1.5 1.5 0 0 0-2.04-1.04L2.7 9.27c-1.4.55-1.35 2.56.07 3.04l4.4 1.47 1.7 5.26c.42 1.31 2.1 1.64 2.98.6l2.3-2.74 4.42 3.25c1.04.77 2.53.2 2.78-1.07l2.6-14.5a1.5 1.5 0 0 0-.01-1.03ZM8.4 12.66l8.9-5.6c.4-.25.8.3.46.62l-6.86 6.4a2 2 0 0 0-.6 1.15l-.25 1.84-1.65-4.41Z" />
                  </svg>
                )}
              </span>
              {c.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        class="contacts__address"
        href={address.mapHref}
        target="_blank"
        rel="noopener noreferrer"
        set:html={address.text}
      />

      <FormSubmission client:load buttonText="Оставить заявку" variant="outlined" size="normal" />
    </div>

    <div class="contacts__map">
      <iframe
        src="https://widgets.2gis.com/widget?type=firmsonmap&options=%7B%22pos%22%3A%7B%22lat%22%3A56.838011%2C%22lon%22%3A60.597474%2C%22zoom%22%3A16%7D%2C%22opt%22%3A%7B%22city%22%3A%22ekaterinburg%22%7D%2C%22org%22%3A%221267165676248326%22%7D"
        width="100%"
        height="400"
        allow="fullscreen"
        title="Офис Formit на карте 2ГИС"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .contacts__inner {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .contacts__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contacts__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contacts__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }

  .contacts__link:hover {
    color: var(--color-accent-primary);
  }

  .contacts__head {
    margin-bottom: var(--space-4);
  }

  .contacts__link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-soft);
    color: var(--color-accent-primary);
    flex-shrink: 0;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .contacts__link:hover .contacts__link-icon {
    background: var(--color-accent-primary);
    color: var(--color-text-inverse);
  }

  .contacts__address {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-loose);
    transition: color var(--transition-fast);
  }

  .contacts__address:hover {
    color: var(--color-accent-primary);
  }

  /* --- Карта --- */
  .contacts__map {
    height: 400px;
    border-radius: var(--card-border-radius);
    overflow: hidden;
    border: var(--card-border);
    background: var(--color-bg-secondary);
  }

  .contacts__map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  @media (max-width: 768px) {
    .contacts__inner {
      grid-template-columns: 1fr;
    }

    .contacts__map {
      height: 280px;
    }
  }
</style>
