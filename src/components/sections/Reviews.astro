---
import { asset } from '../../utils/asset';
const reviews = [
  {
    avatar: asset('/images/yurijNagovicyn.9UEzkdA7_Z1XKrRT.webp'),
    name: 'Юрий Наговицын',
    role: 'BIM-аналитик',
    company: 'Страна Девелопмент',
    city: 'г. Тюмень',
    paragraphs: [
      'На стадии предпроектных работ нам приходится рассматривать множество вариантов объемно-планировочных решений. Любая допущенная ошибка на этой стадии несет в себе большие потери в деньгах и времени.',
      'Продукты Formit обеспечивают:\n— Возможность выборочного экспорта необходимых элементов из Revit;\n— Быстрый расчет инсоляции;\n— Наглядное отображение результатов.',
    ],
  },
  {
    avatar: asset('/images/yaroslavDrauzin.DQO3lqYE_ePEJe.webp'),
    name: 'Ярослав Драузин',
    role: 'Архитектор',
    company: 'Архитектурно-девелоперская компания АРЗИЗ',
    city: 'г. Владивосток',
    paragraphs: [
      'Работая в сфере проектирования многоэтажного жилья часто сталкиваемся со сложным рельефом и существующей застройкой, сервис Formit еще на предпроектной стадии позволяет быстро и точно находить корректные объемно-планировочные решения с учетом санитарно-гигиенических нормативных требований.',
      'Сервис обрабатывает большой объем помещений и отлично справляется, когда требуется проверка целого комплекса зданий.',
    ],
  },
  {
    avatar: asset('/images/alexanderDavydov.CAVeu2W__tGp9O.webp'),
    name: 'Александр Давыдов',
    role: 'BIM-координатор',
    company: 'ООО «Сибтехпроект»',
    city: 'г. Томск',
    paragraphs: [
      'Наша компания выполняет проекты быстро и качественно, а для достижения таких результатов нам не обойтись без средств автоматизации. Когда мы искали, как можно улучшить технологию по расчету инсоляции и КЕО, мы проанализировали, что есть на рынке, и остановились на Formit!',
      'С помощью данного продукта, мы получаем цельную картину по расчету всего объекта, что позволяет нам быть уверенными в верности принятых проектных решениях!',
    ],
  },
  {
    avatar: asset('/images/anastasiyaYambulatova.CnT3T0S8_Z1IH64Q.webp'),
    name: 'Анастасия Ямбулатова',
    role: 'Архитектор',
    company: 'ООО «Прогресс»',
    city: 'г. Астрахань',
    paragraphs: [
      'Работа с плагином Formit началась с фразы: «Давай прикрутим его к Revit». В нашей компании развито BIM-проектирование, в связи с чем основной критерий выбора пал на данный плагин.',
      'Программа позволяет за короткий промежуток времени подготовить отчет по расчету инсоляции и КЕО, что удовлетворяет скорость и темп нашей организации.',
    ],
  },
];
---

<section id="reviews" class="section section--bg-secondary reviews fade-in">
  <!-- Декоративный круг на фоне -->
  <div class="reviews__bg-circle" aria-hidden="true"></div>

  <div class="container">
    <h2 class="section-title h2">Отзывы</h2>

    <div class="reviews__cards">
      {reviews.map(r => (
        <article class="card card--interactive review-card">
          <div class="review-card__profile">
            <img
              class="review-card__avatar"
              src={r.avatar}
              alt={r.name}
              width="80"
              height="80"
              loading="lazy"
              decoding="async"
            />
            <div>
              <h4 class="review-card__name">{r.name}</h4>
              <p class="review-card__role">{r.role}</p>
              <p class="review-card__company">{r.company}</p>
              <p class="review-card__city">{r.city}</p>
            </div>
          </div>
          <div class="review-card__text">
            {r.paragraphs.map(p => <p>{p}</p>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    position: relative;
    overflow: hidden;
  }

  .reviews__bg-circle {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-blue-bright) 0%, transparent 70%);
    opacity: 0.05;
    top: -200px;
    right: -200px;
    pointer-events: none;
  }

  .reviews__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .review-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .review-card__profile {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .review-card__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--color-border);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent-primary) 12%, transparent);
  }

  .review-card__name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
  }

  .review-card__role {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }

  .review-card__company {
    font-size: var(--font-size-sm);
    color: var(--color-accent-primary);
    font-weight: var(--font-weight-medium);
    margin-top: var(--space-1);
  }

  .review-card__city {
    font-size: var(--font-size-xs);
    color: var(--color-text-dimmed);
    margin-top: var(--space-1);
  }

  .review-card__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .review-card__text p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-loose);
    white-space: pre-line;
  }

  @media (max-width: 768px) {
    .reviews__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
