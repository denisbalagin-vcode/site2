---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Audience from '../components/sections/Audience.astro';
import Stages from '../components/sections/Stages.astro';
import Video from '../components/sections/Video.astro';
import Expertises from '../components/sections/Expertises.astro';
import Certified from '../components/sections/Certified.astro';
import DemoCTA from '../components/sections/DemoCTA.astro';
import Reviews from '../components/sections/Reviews.astro';
import Team from '../components/sections/Team.astro';
import Pricing from '../components/sections/Pricing.astro';
import Contacts from '../components/sections/Contacts.astro';
---

<Layout>
  <Header currentProduct="pd" showSectionNav={true} />

  <main>
    <Hero />
    <Audience />
    <Stages />
    <Video />
    <Expertises />
    <Certified />
    <DemoCTA />
    <Reviews />
    <Pricing />
    <Contacts />
    <Team />
  </main>

  <Footer />
</Layout>
