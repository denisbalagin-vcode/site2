---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/articles/ArticleCard.astro';
import { getAllArticles, getAllTags } from '../../lib/articles';

const articles = await getAllArticles();
const tags = await getAllTags();
---

<Layout
  title="Статьи Formit — инсоляция, КЕО и расчёты"
  description="Статьи команды Formit об инсоляции, КЕО, работе с Revit-моделями и прохождении экспертизы."
>
  <Header showSectionNav={false} showArticlesLink={false} showHomeLink={true} />

  <main>
    <section class="section articles-hero">
      <div class="container">
        <p class="articles-hero__badge">Блог команды</p>
        <h1 class="articles-hero__title h2">Статьи</h1>
        <p class="articles-hero__lead">
          Материалы наших специалистов об&nbsp;инсоляции, КЕО, работе
          с&nbsp;Revit-моделями и&nbsp;прохождении экспертизы.
        </p>
      </div>
    </section>

    <section class="section articles-list">
      <div class="container">
        {tags.length > 0 && (
          <div class="articles-filter" data-articles-filter>
            <button
              type="button"
              class="articles-filter__chip is-active"
              data-tag-filter="all"
            >
              Все
            </button>
            {tags.map((tag) => (
              <button type="button" class="articles-filter__chip" data-tag-filter={tag}>
                {tag}
              </button>
            ))}
          </div>
        )}

        {articles.length === 0 ? (
          <p class="articles-empty">Пока нет опубликованных статей. Скоро здесь появятся материалы.</p>
        ) : (
          <div class="cards-grid cards-grid--3 fade-in" data-articles-grid>
            {articles.map((article) => (
              <div class="articles-grid__item" data-tags={article.tags.join('|')}>
                <ArticleCard article={article} />
              </div>
            ))}
          </div>
        )}

        <p class="articles-empty" data-no-results hidden>
          Нет статей с выбранным тегом.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .articles-hero {
    padding-bottom: var(--space-6);
  }

  .articles-hero__badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    background: var(--color-accent-soft);
    color: var(--color-accent-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .articles-hero__title {
    margin-top: var(--space-4);
  }

  .articles-hero__lead {
    margin-top: var(--space-4);
    max-width: 60ch;
    font-size: var(--font-size-md);
    line-height: var(--line-height-loose);
    color: var(--color-text-secondary);
  }

  .articles-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .articles-filter__chip {
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-strong);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    background: transparent;
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .articles-filter__chip:hover {
    border-color: var(--color-accent-primary);
    color: var(--color-accent-primary);
  }

  .articles-filter__chip.is-active {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    color: var(--color-text-inverse);
  }

  .articles-grid__item {
    display: flex;
  }

  .articles-grid__item[hidden] {
    display: none;
  }

  .articles-empty {
    color: var(--color-text-secondary);
    font-size: var(--font-size-md);
  }
</style>

<script>
  function initArticlesFilter() {
    const filter = document.querySelector<HTMLElement>('[data-articles-filter]');
    const items = Array.from(document.querySelectorAll<HTMLElement>('.articles-grid__item'));
    const noResults = document.querySelector<HTMLElement>('[data-no-results]');
    if (!filter || !items.length) return;

    const chips = Array.from(filter.querySelectorAll<HTMLButtonElement>('[data-tag-filter]'));

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tagFilter ?? 'all';
        chips.forEach((c) => c.classList.toggle('is-active', c === chip));

        let visible = 0;
        items.forEach((item) => {
          const tags = (item.dataset.tags ?? '').split('|');
          const show = tag === 'all' || tags.includes(tag);
          item.hidden = !show;
          if (show) visible += 1;
        });

        if (noResults) noResults.hidden = visible !== 0;
      });
    });
  }

  initArticlesFilter();
  document.addEventListener('astro:page-load', initArticlesFilter);
</script>
