---
/*
  Секция-баннер: приглашение перейти на отдельную страницу
  с интерактивным демо продукта (/demo).
*/
import Button from '../ui/Button.astro';
import { asset } from '../../utils/asset';

const points = [
  'Без установки и регистрации',
  'Реальный интерфейс расчёта',
  'Пример готового отчёта',
];
---

<section id="demo-cta" class="section demo-cta fade-in">
  <div class="container">
    <div class="demo-cta__card">
      <!-- Декоративные «световые» круги -->
      <span class="demo-cta__glow demo-cta__glow--1" aria-hidden="true"></span>
      <span class="demo-cta__glow demo-cta__glow--2" aria-hidden="true"></span>

      <div class="demo-cta__content">
        <span class="demo-cta__badge">Демо продукта</span>
        <h2 class="demo-cta__title">Попробуйте Formit прямо в браузере</h2>
        <p class="demo-cta__desc">
          Откройте интерактивное демо и&nbsp;пройдите весь сценарий расчёта
          инсоляции и&nbsp;КЕО на&nbsp;готовом примере — ничего устанавливать
          не&nbsp;нужно.
        </p>

        <ul class="demo-cta__points" role="list">
          {points.map(point => (
            <li class="demo-cta__point">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <span>{point}</span>
            </li>
          ))}
        </ul>

        <div class="demo-cta__actions">
          <Button variant="filled" size="large" href={asset('/demo')} class="demo-cta__btn">
            Открыть демо продукта
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-cta__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    padding: clamp(var(--space-8), 6vw, var(--space-20));
    background: var(--gradient-primary);
    color: var(--color-text-inverse);
    box-shadow: var(--shadow-lg);
  }

  .demo-cta__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(8px);
  }

  .demo-cta__glow--1 {
    width: 38%;
    aspect-ratio: 1;
    top: -25%;
    right: -8%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-blue-bright) 60%, transparent) 0%, transparent 70%);
  }

  .demo-cta__glow--2 {
    width: 30%;
    aspect-ratio: 1;
    bottom: -30%;
    left: -5%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-green-main) 35%, transparent) 0%, transparent 70%);
  }

  .demo-cta__content {
    position: relative;
    z-index: 1;
    max-width: 60ch;
  }

  .demo-cta__badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-white) 18%, transparent);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .demo-cta__title {
    margin-top: var(--space-5);
    font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-3xl));
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
  }

  .demo-cta__desc {
    margin-top: var(--space-4);
    font-size: var(--font-size-md);
    line-height: var(--line-height-loose);
    color: color-mix(in srgb, var(--color-white) 88%, transparent);
  }

  .demo-cta__points {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }

  .demo-cta__point {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .demo-cta__point svg {
    flex-shrink: 0;
    color: var(--color-green-bg);
  }

  .demo-cta__actions {
    margin-top: var(--space-8);
  }

  /* Кнопка на градиентном фоне — белая с синим текстом */
  .demo-cta__btn.btn--filled {
    background: var(--color-white);
    color: var(--color-accent-primary);
  }

  .demo-cta__btn.btn--filled:hover {
    opacity: 0.9;
  }
</style>
