---
/*
  Секция «Formit в действии» — видео-обзор продукта.
  Один крупный обзорный ролик + несколько коротких видео по отдельным
  возможностям. Постеры берутся из существующих изображений; реальные
  ролики подключаются через пропсы src/embed у <VideoPlayer> (см. ниже).
*/
import VideoPlayer from '../ui/VideoPlayer.astro';
import Button from '../ui/Button.astro';
import { asset } from '../../utils/asset';

// Короткие видео по возможностям. Чтобы подключить реальный ролик,
// добавьте к объекту поле `src` (файл) или `embed` (iframe-ссылка).
const clips = [
  {
    poster: asset('/images/expertisesMap.BKsQ8uxG.png'),
    title: 'Загрузка Revit-модели',
    desc: 'Синхронизация модели в один клик — без экспорта и конвертаций.',
    duration: '1:12',
  },
  {
    poster: asset('/images/verificationCertificatePreview.Bfme0gof.webp'),
    title: 'Расчёт инсоляции и КЕО',
    desc: '~1000 светопроёмов в минуту с учётом окружающей застройки.',
    duration: '2:05',
  },
  {
    poster: asset('/images/certificateOfConformityPreview.BR6acEUv.webp'),
    title: 'Готовый отчёт для экспертизы',
    desc: 'Автоматическое формирование отчёта по действующим нормам.',
    duration: '1:40',
  },
];
---

<section id="video" class="section section--bg-primary video-section fade-in">
  <div class="container">
    <!-- Заголовок секции -->
    <div class="video-section__head">
      <span class="video-section__eyebrow">
        <span class="video-section__eyebrow-dot" aria-hidden="true"></span>
        Видео-обзор
      </span>
      <h2 class="section-title h2 video-section__title">Смотрите Formit в действии</h2>
      <p class="video-section__lead">
        Несколько коротких роликов покажут весь путь — от&nbsp;загрузки модели
        до&nbsp;готового отчёта. Посмотрите, как это работает, прямо&nbsp;здесь.
      </p>
    </div>

    <!-- Главный обзорный ролик -->
    <div class="video-section__feature">
      <VideoPlayer
        poster={asset('/images/insolatedBuilding.BsJLrvJH.webp')}
        title="Обзор сервиса Formit — расчёт инсоляции и КЕО"
        duration="3:24"
        class="video-section__feature-player"
      />
    </div>

    <!-- Сетка коротких видео по возможностям -->
    <div class="video-section__grid">
      {clips.map(clip => (
        <article class="video-clip">
          <VideoPlayer
            poster={clip.poster}
            title={clip.title}
            duration={clip.duration}
          />
          <div class="video-clip__body">
            <h3 class="video-clip__title">{clip.title}</h3>
            <p class="video-clip__desc">{clip.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Переход к интерактивному демо -->
    <div class="video-section__cta">
      <Button variant="filled" size="large" href={asset('/demo')}>
        Открыть интерактивное демо
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </Button>
    </div>
  </div>
</section>

<style>
  .video-section__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .video-section__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-navbar);
    background: var(--color-accent-soft);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
  }

  .video-section__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent-primary);
  }

  .video-section__title {
    margin-bottom: 0;
  }

  .video-section__lead {
    max-width: 56ch;
    font-size: var(--font-size-md);
    color: var(--color-text-secondary);
    line-height: var(--line-height-loose);
  }

  .video-section__feature {
    max-width: 960px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .video-section__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .video-clip {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .video-clip__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    margin-bottom: var(--space-2);
  }

  .video-clip__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-normal);
  }

  .video-section__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-12);
  }

  @media (max-width: 900px) {
    .video-section__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }
</style>
