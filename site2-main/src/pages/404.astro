---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import { asset } from '../utils/asset';
---

<Layout
  title="Страница не найдена | Formit"
  description="Запрашиваемая страница не существует. Вернитесь на главную."
>
  <Header />

  <main class="not-found">
    <div class="not-found__inner">
      <div class="not-found__code" aria-hidden="true">404</div>
      <h1 class="not-found__title">Страница не найдена</h1>
      <p class="not-found__desc">
        Возможно, ссылка устарела или страница была удалена.<br />
        Вернитесь на главную — там всё на месте.
      </p>
      <Button variant="filled" size="normal" href={asset('/')}>
        На главную
      </Button>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .not-found {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-24);
    background: var(--color-bg-primary);
  }

  .not-found__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
    max-width: 480px;
    padding-inline: var(--container-padding-x);
  }

  .not-found__code {
    font-size: clamp(5rem, 20vw, 10rem);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    user-select: none;
  }

  .not-found__title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }

  .not-found__desc {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-loose);
  }
</style>
